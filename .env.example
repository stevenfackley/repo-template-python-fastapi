# {{PROJECT_NAME}} — required env. Copy to .env (chmod 600 in prod).
APP_ENV=development
LOG_LEVEL=INFO

# DATABASE_URL=postgres://user:pass@localhost:5432/{{PROJECT_NAME}}
# JWT_SIGNING_KEY=

# S3-compatible object storage (optional). Cloudflare R2 in prod, MinIO locally.
# R2: S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_ENDPOINT=
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=
# S3_FORCE_PATH_STYLE=true
# S3_PUBLIC_BASE_URL=
