{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8080"],
      "env": { "APP_ENV": "development", "PYTHONPATH": "${workspaceFolder}/src" },
      "cwd": "${workspaceFolder}",
      "jinja": true
    },
    {
      "name": "pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-v", "tests"],
      "env": { "PYTHONPATH": "${workspaceFolder}/src" }
    }
  ]
}
